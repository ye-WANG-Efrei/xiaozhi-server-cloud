# ============================================================
# 小智 ESP32 Server — 部署参数配置
# 使用方法：
#   cp .env.example .env
#   按实际情况修改 .env，然后执行：
#   docker compose -f docker-compose_deploy.yml up -d
# ============================================================

# ------------------------------------------------------------
# 网络地址
# ------------------------------------------------------------
# 服务器公网 IP（ESP32 设备通过公网连接时使用）
SERVER_PUBLIC_IP=1.2.3.4

# 服务器内网 IP（局域网内设备连接时使用；纯公网部署时可与公网IP相同）
SERVER_LAN_IP=192.168.1.100

# ------------------------------------------------------------
# 端口
# ------------------------------------------------------------
# WebSocket 服务端口（ESP32 设备连接）
WS_PORT=8000

# HTTP 服务端口（OTA 升级 + 视觉分析接口）
HTTP_PORT=8003

# 智控台（manager-web）端口
WEB_PORT=8002

# ------------------------------------------------------------
# 数据库
# ------------------------------------------------------------
MYSQL_ROOT_PASSWORD=your_strong_password
MYSQL_DATABASE=xiaozhi_esp32_server

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
# 留空表示不设密码；如需密码请填写
REDIS_PASSWORD=

# ------------------------------------------------------------
# 时区
# ------------------------------------------------------------
TZ=Asia/Shanghai
